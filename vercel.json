{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": "echo skip",
  "framework": null,
  "functions": {
    "api/*.js": {
      "maxDuration": 60,
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/trailer-sync",
      "schedule": "0 10 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
